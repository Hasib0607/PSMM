# ─── Live site (me.ecommercex.store) ───────────────────────────────
NODE_ENV=production
AUTH_URL="https://me.ecommercex.store"
AUTH_TRUST_HOST=true

# ─── PostgreSQL (REQUIRED) ───────────────────────────────────────
# Hosting panel থেকে database create করো, তারপর connection string দাও।
# Format: postgresql://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
#
# Same VPS + Docker Compose:
#   DATABASE_URL="postgresql://psmm:psmm@127.0.0.1:5432/psmm"
#
# Hosting panel (cPanel / custom):
#   DATABASE_URL="postgresql://dbuser:YOUR_PASSWORD@127.0.0.1:5432/psmm_db"
#
# Note: Database NAME must exist in PostgreSQL — deploy only creates TABLES (auto via npm run build)
DATABASE_URL="postgresql://psmm:CHANGE_ME@127.0.0.1:5432/psmm"

# ─── Redis (queue + rate limit) ────────────────────────────────────
REDIS_URL="redis://127.0.0.1:6379"

# ─── Auth (REQUIRED) ───────────────────────────────────────────────
# openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# ─── OpenAI ────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─── Facebook session encryption (REQUIRED in production) ──────────
# openssl rand -hex 32
ENCRYPTION_KEY="generate-with-openssl-rand-hex-32"

# ─── Telegram (optional) ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""

# ─── Worker (optional) ─────────────────────────────────────────────
DISABLE_EMBEDDED_WORKER=true
PAUSE_AUTOMATION=false
